EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua_chave_evolution
EVOLUTION_INSTANCE_NAME=nome_da_instancia

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role

GEMINI_API_KEY=sua_chave_gemini
# Opcional: sobrescreve o modelo padrão (ex: gemini-1.5-pro)
# GEMINI_MODEL=gemini-1.5-flash

# Opcional: OpenAI como fallback
# OPENAI_API_KEY=sua_chave_openai

EMBEDDING_DIMENSION=768
KNOWLEDGE_ENABLED=false
KNOWLEDGE_ROLLOUT_PERCENT=10

PORT=3000
NODE_ENV=development
DASHBOARD_URL=https://lumiz-financeiro.vercel.app
# URL do frontend autorizada pelo CORS em produção (obrigatório em NODE_ENV=production)
FRONTEND_URL=https://lumiz-financeiro.vercel.app
# Use /setup (novo frontend) ou /setup-account (compatibilidade legado)
DASHBOARD_SETUP_ROUTE=/setup-account
# Opcional: vídeo público enviado ao final do onboarding como teaser do dashboard futuro
# ONBOARDING_DASHBOARD_TEASER_VIDEO_URL=https://cdn.seudominio.com/lumiz-dashboard-teaser.mp4
# Opcional: link de agendamento para CTA pós-onboarding ("falar com o Eric")
# FOUNDER_CALL_URL=https://cal.com/lumiz/intro

REDIS_URL=redis://localhost:6379
# Cache e filas Redis. No serviço HTTP use QUEUE_WORKER_ENABLED=false;
# no serviço worker use QUEUE_WORKER_ENABLED=true.
REDIS_CACHE_ENABLED=true
REDIS_QUEUE_ENABLED=true
QUEUE_WORKER_ENABLED=false
# Reenvio resiliente de respostas WhatsApp quando a Evolution falha temporariamente.
WHATSAPP_OUTBOUND_QUEUE_ENABLED=true
WHATSAPP_OUTBOUND_WORKER_ENABLED=true
# Alertas automáticos por WhatsApp só disparam para profiles.alertas_whatsapp_ativos=true.
WHATSAPP_DAILY_BRIEFING_ENABLED=false
WHATSAPP_VALIDITY_ALERTS_ENABLED=false
# Opcional: número máximo de tentativas de reconexão com Redis (padrão: 10)
# REDIS_MAX_RECONNECT_ATTEMPTS=10

# OCR.space API Key (25k requisições/mês grátis)
OCR_SPACE_API_KEY=sua_chave_ocrspace

# Google Vision (alternativa ao OCR.space para documentos)
# GOOGLE_VISION_API_KEY=sua_chave_google_vision
# GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/credentials.json

# Monitoramento (Sentry)
SENTRY_DSN=

# Segurança do endpoint de cron jobs (recomendado em produção)
CRON_SECRET=gere-uma-string-aleatoria-forte

# Token do endpoint de métricas (quando exposto)
METRICS_TOKEN=gere-outro-token-forte

# Runtime flags
WEBHOOK_DEDUP_ENABLED=true
WEBHOOK_DEDUP_TTL_SECONDS=300
# Opcional: quando configurados, POSTs no webhook passam a exigir assinatura/segredo.
# META_APP_SECRET=app_secret_da_meta
# EVOLUTION_WEBHOOK_SECRET=segredo_compartilhado_com_a_evolution
AI_PRIMARY_PROVIDER=gemini
OPENAI_FALLBACK_ENABLED=false

# Captura multimodal / OpenAI
# Usado por audioTranscriptionService (Whisper) e fallback multimodal.
# OPENAI_API_KEY=sua_chave_openai
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=pt
CAPTURE_LOW_CONFIDENCE_THRESHOLD=0.8

# Feature flags (JSON global opcional; flags por usuário ficam na tabela feature_flags)
# FEATURE_FLAGS={"alter_enabled":false}
#
# --- Agente WhatsApp (Gemini + tools) ---
# Precedência: Supabase feature_flags (por user_id, depois global) > FEATURE_FLAGS JSON > vars MAIÚSCULAS > default false.
# Guia completo: docs/AGENTIC_ENV_RAILWAY.md
#
# Chaves no JSON: agentic_shadow_mode | agentic_router_enabled | agentic_tools_enabled | agentic_onboarding_enabled | profile_builder_enabled
#
# Agente ligado (local / copiar para Railway como uma variável FEATURE_FLAGS):
# FEATURE_FLAGS={"agentic_router_enabled":true,"agentic_tools_enabled":true,"agentic_shadow_mode":false}
#
# Equivalente sem JSON (camada env booleana):
# AGENTIC_ROUTER_ENABLED=true
# AGENTIC_TOOLS_ENABLED=true
# AGENTIC_SHADOW_MODE=false
#
# Só shadow (mede decisão agentic, resposta continua determinística):
# FEATURE_FLAGS={"agentic_shadow_mode":true,"agentic_router_enabled":true,"agentic_tools_enabled":true}
#
# Agente desligado:
# FEATURE_FLAGS={"agentic_router_enabled":false,"agentic_tools_enabled":false,"agentic_shadow_mode":false}
#
# Seed global no DB (opcional): supabase/migrations/20260512203001_seed_global_agentic_feature_flags.sql

# Alter (mock por padrão; real quando ALTER_CLIENT_ID + ALTER_CLIENT_SECRET estiverem definidos)
# Credenciais OAuth2 client_credentials — guardar em vault (1Password ou equivalente).
ALTER_ENABLED=false
# ALTER_CLIENT_ID=seu_client_id_alter
# ALTER_CLIENT_SECRET=seu_client_secret_alter
# ALTER_API_URL=https://app.alterbr.com  # opcional; já é o padrão
# ALTER_WEBHOOK_SECRET=secret_hmac_fornecido_pela_alter_em_canal_privado
ALTER_FEE_SPOT_PCT=0.025
ALTER_FEE_SPOT_MIN_PCT=0.015
ALTER_FEE_SPOT_MAX_PCT=0.045
ALTER_RECOMEND_SAFETY_PCT=0.10
HEALTH_SCORE_COBERTURA_FORNECEDOR_PESO=10

# Nível de log: error | warn | info (padrão: info)
# LOG_LEVEL=info

# WhatsApp Business API Oficial (Meta Cloud API)
# Necessário ao migrar do chip físico + Evolution QR Code para API oficial.
# WA_WEBHOOK_VERIFY_TOKEN=um_token_secreto_que_voce_escolhe  # qualquer string aleatória
# WA_PHONE_NUMBER_ID=123456789                                # ID do número no painel Meta
# WA_ACCESS_TOKEN=EAAxxxxxxx                                  # Token permanente da Meta
# WABA_ID=987654321                                           # WhatsApp Business Account ID
# WA_GRAPH_API_VERSION=v23.0                                  # versão Graph API usada no download/envio oficial
# WHATSAPP_ASYNC_MEDIA_PROCESSING=false                       # envia aviso imediato ao receber PDF/foto; resultado final segue após OCR
# WHATSAPP_PROCESSING_WARN_MS=5000                            # loga WA_LATENCY como warning se processamento passar desse limite
# WHATSAPP_SEND_WARN_MS=3000                                  # loga WA_LATENCY como warning se envio passar desse limite
# WHATSAPP_TOTAL_WARN_MS=7000                                 # loga WA_LATENCY como warning se tempo total passar desse limite
