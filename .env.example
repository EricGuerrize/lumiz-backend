EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua_chave_evolution
EVOLUTION_INSTANCE_NAME=nome_da_instancia

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role

GEMINI_API_KEY=sua_chave_gemini
# Opcional: sobrescreve o modelo padrão (ex: gemini-1.5-pro)
# GEMINI_MODEL=gemini-1.5-flash

# Opcional: OpenAI como fallback
# OPENAI_API_KEY=sua_chave_openai

EMBEDDING_DIMENSION=768
KNOWLEDGE_ENABLED=false
KNOWLEDGE_ROLLOUT_PERCENT=10

PORT=3000
NODE_ENV=development
DASHBOARD_URL=https://lumiz-financeiro.vercel.app
# URL do frontend autorizada pelo CORS em produção (obrigatório em NODE_ENV=production)
FRONTEND_URL=https://lumiz-financeiro.vercel.app
# Use /setup (novo frontend) ou /setup-account (compatibilidade legado)
DASHBOARD_SETUP_ROUTE=/setup-account

REDIS_URL=redis://localhost:6379
# Opcional: número máximo de tentativas de reconexão com Redis (padrão: 10)
# REDIS_MAX_RECONNECT_ATTEMPTS=10

# OCR.space API Key (25k requisições/mês grátis)
OCR_SPACE_API_KEY=sua_chave_ocrspace

# Google Vision (alternativa ao OCR.space para documentos)
# GOOGLE_VISION_API_KEY=sua_chave_google_vision
# GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/credentials.json

# Monitoramento (Sentry)
SENTRY_DSN=

# Segurança do endpoint de cron jobs (recomendado em produção)
CRON_SECRET=gere-uma-string-aleatoria-forte

# Token do endpoint de métricas (quando exposto)
METRICS_TOKEN=gere-outro-token-forte

# Runtime flags
PROCESS_ROLE=api
QUEUE_CONSUMER_ENABLED=false
WEBHOOK_DEDUP_ENABLED=true
WEBHOOK_DEDUP_TTL_SECONDS=300
AI_PRIMARY_PROVIDER=gemini
OPENAI_FALLBACK_ENABLED=false

# Nível de log: error | warn | info (padrão: info)
# LOG_LEVEL=info
